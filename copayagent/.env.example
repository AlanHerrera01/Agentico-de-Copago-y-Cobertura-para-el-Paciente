# ===========================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# Copia este archivo a .env y completa tus valores
# ===========================================

# OpenAI Configuration (Requerido para IA)
OPENAI_API_KEY=sk-your-real-openai-api-key-here

# AI Provider Configuration
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# GitHub Models Configuration (Opcional)
# GITHUB_MODELS_API_KEY=ghp_your-github-models-api-key-here

# Notion Configuration (Requerido para datos reales)
NOTION_TOKEN=secret_your-real-notion-token-here
notion.database.pacientes=your-real-pacientes-database-id
notion.database.planes=your-real-plans-database-id
notion.database.hospitales=your-real-hospitales-database-id
notion.database.especialidades=your-real-especialidades-database-id

# ===========================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores placeholder con tus claves reales
# 3. Reinicia la aplicación
# 4. El sistema validará todas las conexiones al inicio
# ===========================================
